# BotForge Secrets
# Kopiere diese Datei als .env und fülle die Werte aus.

# === Discord ===
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_CLIENT_SECRET=your-client-secret-here
DISCORD_PUBLIC_KEY=your-public-key-here
PREFIX=!

# === Dashboard OAuth ===
# Für Production: https://deinedomain.railway.app/callback
REDIRECT_URI=http://localhost:5000/callback
SESSION_SECRET=change-me-to-random-string

# === Database ===
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/botforge

# === Music (Lavalink) ===
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# === Railway ===
PORT=5000
DASHBOARD_HOST=0.0.0.0
